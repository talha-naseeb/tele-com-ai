PORT=8080
NODE_ENV=development
# Atlas example: mongodb+srv://user:pass@cluster.mongodb.net/telecom_demo?retryWrites=true&w=majority
MONGODB_URI=
DEFAULT_CALLBACK_SLA_HOURS=2

# Production Retell: verifies x-retell-signature over the raw POST body (see docs/retell-apis.md).
RETELL_API_KEY=

# Optional dev fallback when RETELL_API_KEY is unset: require header x-api-key to match.
API_SECRET_KEY=
